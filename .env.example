# Supabase Configuration
# Copy this file to .env.local and fill in your actual Supabase credentials

# Public Supabase URL (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public Supabase Anon Key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (KEEP SECRET - server-side only)
# Only needed for admin operations with full database access
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
